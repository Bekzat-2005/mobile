# URL бэкенда Skillo (без завершающего слэша).
#
# В Expo-приложении по умолчанию подставляется хост из Metro (LAN IP) — этого
# обычно достаточно, чтобы не ловить «Network request failed» на телефоне.
# Если авто-определение не сработало, задайте IP вручную (тот же, что в QR Expo):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:4000
#
# Android-эмулятор: без .env используется http://10.0.2.2:4000
# iOS-симулятор / веб: чаще всего http://127.0.0.1:4000 или hostname страницы
EXPO_PUBLIC_API_BASE_URL=
